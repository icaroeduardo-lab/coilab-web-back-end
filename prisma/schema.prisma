generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id            String   @id @db.Uuid
  name          String
  projectNumber String   @unique
  description   String
  urlDocument   String?
  status        String   @default("backlog")
  createdAt     DateTime @default(now())
  tasks         Task[]

  @@map("projects")
}

model User {
  id       String  @id @db.Uuid
  name     String
  imageUrl String?
  email    String
  tasks    Task[]  @relation("creator")

  @@map("users")
}

model TaskStatus {
  id    Int    @id @default(autoincrement())
  name  String @unique @db.VarChar(50)
  tasks Task[]

  @@map("task_status")
}

model Applicant {
  id    Int    @id @default(autoincrement())
  name  String
  tasks Task[] @relation("applicant")

  @@map("applicants")
}

model Flow {
  id    Int        @id @default(autoincrement())
  name  String
  tasks TaskFlow[]

  @@map("flows")
}

model Task {
  id          String     @id @db.Uuid
  projectId   String     @db.Uuid
  name        String
  description String
  taskNumber  String     @unique
  priority    String
  creatorId   String     @db.Uuid
  createdAt   DateTime   @default(now())
  applicantId Int
  statusId    Int
  subTasks    SubTask[]
  flows       TaskFlow[]
  applicant   Applicant  @relation("applicant", fields: [applicantId], references: [id])
  creator     User       @relation("creator", fields: [creatorId], references: [id])
  project     Project    @relation(fields: [projectId], references: [id])
  status      TaskStatus @relation(fields: [statusId], references: [id])

  @@index([projectId])
  @@index([creatorId])
  @@map("tasks")
}

model TaskFlow {
  taskId String @db.Uuid
  flowId Int
  flow   Flow   @relation(fields: [flowId], references: [id], onDelete: Cascade)
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@id([taskId, flowId])
  @@map("task_flows")
}

model TaskTool {
  id       Int       @id @default(autoincrement())
  name     String    @db.VarChar(255)
  subTasks SubTask[]

  @@map("task_tools")
}

model SubTaskStatus {
  id       Int       @id @default(autoincrement())
  name     String    @unique @db.VarChar(50)
  subTasks SubTask[]

  @@map("sub_tasks_status")
}

model SubTask {
  id               String        @id @db.Uuid
  taskId           String        @db.Uuid
  idUser           String        @db.Uuid
  expectedDelivery DateTime
  createdAt        DateTime      @default(now())
  startDate        DateTime?
  completionDate   DateTime?
  reason           String?
  typeId           Int
  metadata         Json?
  taskNumber       String        @unique
  statusId         Int
  status           SubTaskStatus @relation(fields: [statusId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  task             Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  toolType         TaskTool      @relation(fields: [typeId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([taskId])
  @@map("sub_tasks")
}
