generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id            String   @id @db.Uuid
  name          String
  projectNumber String   @unique
  description   String
  urlDocument   String?
  status        String   @default("backlog")
  createdAt     DateTime @default(now())
  tasks         Task[]

  @@map("projects")
}

model User {
  id       String  @id @db.Uuid
  name     String
  imageUrl String?
  tasks    Task[]  @relation("creator")

  @@map("users")
}

model TaskStatus {
  id    Int    @id @default(autoincrement())
  name  String @unique
  tasks Task[]

  @@map("task_status")
}

model Applicant {
  id    Int    @id @default(autoincrement())
  name  String
  tasks Task[] @relation("applicant")

  @@map("applicants")
}

model Flow {
  id    Int        @id @default(autoincrement())
  name  String
  tasks TaskFlow[]

  @@map("flows")
}

model Task {
  id          String    @id @db.Uuid
  projectId   String    @db.Uuid
  name        String
  description String
  taskNumber  String    @unique
  priority    String
  statusId    Int
  applicantId Int
  creatorId   String    @db.Uuid
  createdAt   DateTime  @default(now())
  project     Project   @relation(fields: [projectId], references: [id])
  status      TaskStatus @relation(fields: [statusId], references: [id])
  applicant   Applicant @relation("applicant", fields: [applicantId], references: [id])
  creator     User      @relation("creator", fields: [creatorId], references: [id])
  subTasks    SubTask[]
  flows       TaskFlow[]

  @@index([projectId])
  @@index([applicantId])
  @@index([creatorId])
  @@index([statusId])
  @@map("tasks")
}

model TaskFlow {
  taskId String @db.Uuid
  flowId Int
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  flow   Flow   @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@id([taskId, flowId])
  @@map("task_flows")
}

model TaskTool {
  id       Int       @id @default(autoincrement())
  name     String    @db.VarChar(255)
  subTasks SubTask[]

  @@map("task_tools")
}

model SubTask {
  id               String    @id @db.Uuid
  taskId           String    @db.Uuid
  idUser           String    @db.Uuid
  status           String
  typeId           Int
  taskNumber       String    @unique
  expectedDelivery DateTime
  createdAt        DateTime  @default(now())
  startDate        DateTime?
  completionDate   DateTime?
  reason           String?
  metadata         Json?
  task             Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  toolType         TaskTool  @relation(fields: [typeId], references: [id])

  @@index([taskId])
  @@map("sub_tasks")
}
